# ─────────────────────────────────────────────────────────────
# stockbot 환경변수 예시 — 실제 값은 .env 에 넣는다(.env 는 git 무시).
# 1차 목표는 KIS 모의투자(paper) 전용. 실계좌 키는 넣지 않는다(3장 안전 제약).
# 시크릿은 평문 커밋 금지 — 이 파일에는 placeholder 만 둔다.
# ─────────────────────────────────────────────────────────────

# 실행 모드: live(모의투자) | backtest
RUN_MODE=live

# 브로커 환경: paper(모의투자) | prod(실거래, 1차에서는 사용 금지)
KIS_ENV=paper

# ── KIS 모의투자 계정 ──
HTS_ID=your_hts_id
MOCK_ACCOUNT=00000000-01
MOCK_KIS_API_KEY=__PLACEHOLDER__
MOCK_KIS_API_SECRET=__PLACEHOLDER__

# ── KIS 실거래 계정 (1차 비범위, 미사용) ──
KIS_API_KEY=__PLACEHOLDER__
KIS_API_SECRET=__PLACEHOLDER__

# ── Postgres ──
POSTGRES_USER=stockbot
POSTGRES_PASSWORD=stockbot
POSTGRES_DB=stockbot
POSTGRES_PORT=5432
DATABASE_URL=postgresql://stockbot:stockbot@localhost:5432/stockbot

# ── Redis ──
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── LLM (이벤트 enrichment + 섹터 신호, 8장) ──
ANTHROPIC_API_KEY=__PLACEHOLDER__
LLM_MODEL=claude-opus-4-8
EVENT_PROMPT_VERSION=v1

# ── 이벤트 수집 (8장) ──
DART_API_KEY=__PLACEHOLDER__

# ── 알림 (Notifier, 웹훅 URL은 시크릿 아님) ──
NOTIFIER_WEBHOOK_URL=

# ── 리스크 기본값 (6장) ──
MAX_POSITIONS=5
PER_SYMBOL_WEIGHT_CAP=0.10
DAILY_LOSS_LIMIT_PCT=0.03

# ── 로깅 ──
LOG_LEVEL=info
